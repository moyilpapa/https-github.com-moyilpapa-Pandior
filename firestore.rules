rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator: User Profile
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'streak', 'xp', 'level'])
        && data.keys().size() == 5
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.streak is int && data.streak >= 0
        && data.xp is int && data.xp >= 0
        && data.level is int && data.level >= 1;
    }

    // Entity validator: Event
    function isValidEvent(data) {
      return data.keys().hasAll(['id', 'ownerId', 'title', 'start', 'end', 'category', 'priority'])
        && (data.keys().size() >= 7 && data.keys().size() <= 11)
        && data.ownerId == request.auth.uid
        && data.id is string && isValidId(data.id)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.category is string && data.category in ['work', 'personal', 'meeting', 'other']
        && data.priority is string && data.priority in ['low', 'medium', 'high']
        && data.start is string
        && data.end is string;
    }

    // Entity validator: Task
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'ownerId', 'title', 'dueDate', 'completed'])
        && (data.keys().size() >= 5 && data.keys().size() <= 7)
        && data.ownerId == request.auth.uid
        && data.id is string && isValidId(data.id)
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.completed is bool
        && data.dueDate is string;
    }

    // Match rules (Fortress Patterns)
    match /users/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming())
        && incoming().uid == existing().uid;
      allow delete: if false; // Avoid direct client deletion of profiles
    }

    match /events/{eventId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isSignedIn() && isValidId(eventId) && existing().ownerId == request.auth.uid 
        && isValidEvent(incoming()) && incoming().ownerId == existing().ownerId && incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      allow update: if isSignedIn() && isValidId(taskId) && existing().ownerId == request.auth.uid 
        && isValidTask(incoming()) && incoming().ownerId == existing().ownerId && incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
